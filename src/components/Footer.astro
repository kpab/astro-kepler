---
import Logo from './Logo.astro';

const columns = [
	{
		heading: 'Product',
		links: [
			{ href: '/#features', label: 'Features' },
			{ href: '/#showcase', label: 'Showcase' },
			{ href: '/work', label: 'Work' },
			{ href: '/#pricing', label: 'Pricing' },
		],
	},
	{
		heading: 'Resources',
		links: [
			{ href: '/search', label: 'Search' },
			{ href: '/#faq', label: 'FAQ' },
			{ href: '/blog', label: 'Blog' },
			{ href: '/rss.xml', label: 'RSS' },
		],
	},
	{
		heading: 'Company',
		links: [
			{ href: '#', label: 'About' },
			{ href: '#', label: 'License' },
			{ href: '#', label: 'Twitter' },
			{ href: '#', label: 'GitHub' },
		],
	},
];
---

<footer class="bg-ink text-sky-mist">
	<div
		class="mx-auto grid max-w-[1200px] gap-8 px-8 pt-[60px] pb-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]"
	>
		<div>
			<Logo size="sm" />
			<p class="mt-4 max-w-[260px] text-sm leading-relaxed text-slate-400">
				The versatile Astro starter for blogs, portfolios, and landing pages.
			</p>
		</div>
		{
			columns.map((col) => (
				<div>
					<div class="mb-3.5 text-sm font-bold text-cloud">{col.heading}</div>
					<div class="flex flex-col gap-2.5 text-sm">
						{col.links.map((link) => (
							<a href={link.href} class="text-sky-mist hover:text-orange">
								{link.label}
							</a>
						))}
					</div>
				</div>
			))
		}
	</div>
	<div class="border-t border-white/10">
		<div
			class="mx-auto flex max-w-[1200px] flex-wrap justify-between gap-3 px-8 py-5 text-[13px] text-slate-500"
		>
			<span>© 2026 Kepler. All rights reserved.</span>
			<span>Made with Astro ✦</span>
		</div>
	</div>
</footer>
