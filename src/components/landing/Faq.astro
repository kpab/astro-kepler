---
import SectionHeader from './SectionHeader.astro';

const items = [
	{
		q: 'Do I need to know Astro to use Kepler?',
		a: 'Not really. If you can edit HTML and Markdown, you can ship with Kepler. The docs walk you through everything, and most edits happen in plain content files.',
	},
	{
		q: 'Can I use it for client projects?',
		a: 'Yes. The Pro and Team licenses cover unlimited commercial and client projects. Solo covers one personal site.',
	},
	{
		q: "What's included in updates?",
		a: 'New sections, bug fixes, Astro version bumps, and fresh presets. Pro and Team get these for life; Solo for one year.',
	},
	{
		q: 'Is there a refund policy?',
		a: "Absolutely — 14 days, no questions asked. If Kepler isn't the right fit, email us and we'll refund in full.",
	},
];
---

<section
	id="faq"
	class="border-y-4 border-ink bg-linear-160 from-orange-bright from-0% via-orange via-60% to-orange-deep"
>
	<div class="mx-auto max-w-[820px] px-8 py-20">
		<SectionHeader eyebrow="FAQ" title="Questions, answered" on="orange" class="mb-11" />
		<div id="faq-list" class="flex flex-col gap-3.5">
			{
				items.map((item, i) => (
					<div class="overflow-hidden rounded-2xl border-2 border-ink bg-cloud shadow-[5px_5px_0_var(--color-ink)]">
						<button
							type="button"
							data-faq-toggle
							aria-expanded={i === 0 ? 'true' : 'false'}
							class="flex w-full cursor-pointer items-center justify-between gap-4 px-6 py-[22px] text-left font-display text-lg font-semibold text-ink"
						>
							{item.q}
							<span
								data-faq-icon
								class:list={[
									'text-2xl font-bold text-orange transition-transform duration-200',
									i === 0 && 'rotate-45',
								]}
							>
								+
							</span>
						</button>
						<p data-faq-answer hidden={i !== 0} class="px-6 pb-6 text-base leading-relaxed text-slate-600">
							{item.a}
						</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	// アコーディオン: 一度に1つだけ開く（プロトタイプ準拠）
	const list = document.getElementById('faq-list');
	const toggles = list?.querySelectorAll<HTMLButtonElement>('[data-faq-toggle]') ?? [];

	toggles.forEach((btn) => {
		btn.addEventListener('click', () => {
			const wasOpen = btn.getAttribute('aria-expanded') === 'true';
			toggles.forEach((other) => {
				const open = other === btn && !wasOpen;
				other.setAttribute('aria-expanded', String(open));
				other.querySelector('[data-faq-icon]')?.classList.toggle('rotate-45', open);
				const answer = other.parentElement?.querySelector<HTMLElement>('[data-faq-answer]');
				if (answer) answer.hidden = !open;
			});
		});
	});
</script>
