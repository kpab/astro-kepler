---
// 最終CTA — navy 帯 + 軌道モチーフの装飾
---

<section class="relative overflow-hidden bg-linear-160 from-navy to-navy-deep text-cloud">
	<span class="absolute top-7.5 right-[12%] text-[30px] text-orange">✦</span>
	<span class="absolute bottom-10 left-[10%] size-[22px] rotate-[15deg] rounded-md bg-orange"></span>
	<span class="absolute top-15 left-[20%] size-3.5 rounded-full bg-cloud opacity-50"></span>
	<div class="relative z-2 mx-auto max-w-[820px] px-8 py-[90px] text-center">
		<h2 class="text-4xl font-bold tracking-[-0.02em] text-cloud md:text-[52px]">
			Put your next site in orbit
		</h2>
		<p class="mx-auto mt-4.5 max-w-[480px] text-[19px] text-sky-mist">
			Join 12,000+ builders shipping faster with Kepler. One purchase, endless projects.
		</p>
		<div class="mt-8.5 flex flex-wrap justify-center gap-3.5">
			<a
				href="#pricing"
				class="rounded-full bg-orange px-8 py-4 font-bold text-cloud shadow-pop-white transition-transform hover:-translate-x-0.5 hover:-translate-y-0.5"
				>Get Kepler now</a
			>
			<a
				href="#showcase"
				class="rounded-full border-2 border-white/50 bg-transparent px-8 py-4 font-bold text-cloud transition-colors hover:bg-white/10"
				>Browse demos</a
			>
		</div>
	</div>
</section>
