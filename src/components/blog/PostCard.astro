---
import type { Post } from '../../lib/posts';
import { readingTime } from '../../lib/posts';
import TagPill from './TagPill.astro';

interface Props {
	post: Post;
	/** 交互に回転させるためのインデックス */
	index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const minutes = readingTime(post.body);
const dateLabel = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});

// カードを ±1.5° 傾け、hover で直立させる（landing と同じ所作）
const tilt = index % 2 === 0 ? '-rotate-[1.5deg]' : 'rotate-[1.5deg]';
---

<article
	class:list={[
		'group relative flex flex-col rounded-card border-2 border-ink bg-cloud p-6 shadow-pop transition-[transform,box-shadow] duration-200 hover:rotate-0 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-pop-lg',
		tilt,
	]}
>
	{
		tags.length > 0 && (
			<div class="relative z-10 mb-4 flex flex-wrap gap-2">
				{tags.slice(0, 2).map((tag) => (
					<TagPill name={tag} />
				))}
			</div>
		)
	}

	<h3 class="text-[22px] font-bold leading-tight tracking-[-0.02em] text-ink">
		<a href={`/blog/${post.id}`} class="after:absolute after:inset-0 group-hover:text-navy">
			{title}
		</a>
	</h3>

	<div class="mt-2.5 flex items-center gap-2 text-[13px] font-semibold text-ink/55">
		<time datetime={pubDate.toISOString()}>{dateLabel}</time>
		<span aria-hidden="true">·</span>
		<span>{minutes} min read</span>
	</div>

	<p class="mt-3 text-[15px] leading-relaxed text-ink/75">{description}</p>

	<span class="mt-4 inline-flex items-center gap-1 text-[15px] font-bold text-orange-deep">
		Read more
		<span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
	</span>
</article>
