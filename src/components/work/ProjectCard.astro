---
import { Image } from 'astro:assets';
import type { Project } from '../../lib/projects';
import { slugify } from '../../lib/posts';

interface Props {
	project: Project;
	index?: number;
}

const { project, index = 0 } = Astro.props;
const { title, description, category, tech, year, thumbnail } = project.data;

// サムネイル未設定時のプレースホルダ配色（navy 系 / orange 系を交互に）
const themes = [
	'linear-gradient(135deg, #1e3a8a, #152a63)',
	'linear-gradient(135deg, #fb923c, #ea580c)',
	'linear-gradient(135deg, #0f1e42, #1e3a8a)',
];
const bg = themes[index % themes.length];
const monogram = title.charAt(0).toUpperCase();
---

<article
	class="group relative flex flex-col overflow-hidden rounded-card border-2 border-ink bg-cloud shadow-pop transition-[transform,box-shadow] duration-200 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-pop-lg"
	data-category={slugify(category)}
>
	<div class="relative aspect-[16/10] overflow-hidden border-b-2 border-ink">
		{
			thumbnail ? (
				<Image
					src={thumbnail}
					alt={title}
					class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
				/>
			) : (
				<div class="relative h-full w-full" style={`background:${bg}`}>
					<span class="absolute -right-4 -bottom-8 font-display text-[9rem] font-bold leading-none text-cloud/15 select-none">
						{monogram}
					</span>
					<span
						class="absolute top-5 left-5 inline-block size-8 rounded-full border-[3px] border-cloud/70 -rotate-[30deg]"
						aria-hidden="true"
					/>
				</div>
			)
		}
	</div>

	<div class="flex flex-1 flex-col p-6">
		<div class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-[0.08em] text-orange-deep">
			<span>{category}</span>
			<span class="text-ink/30" aria-hidden="true">·</span>
			<span class="text-ink/45">{year}</span>
		</div>

		<h3 class="mt-2 text-[22px] font-bold leading-tight tracking-[-0.02em] text-ink">
			<a href={`/work/${project.id}`} class="after:absolute after:inset-0 group-hover:text-navy">
				{title}
			</a>
		</h3>

		<p class="mt-2.5 text-[15px] leading-relaxed text-ink/70">{description}</p>

		{
			tech.length > 0 && (
				<div class="mt-4 flex flex-wrap gap-1.5">
					{tech.slice(0, 4).map((t) => (
						<span class="rounded-md bg-orange-soft px-2 py-0.5 text-xs font-semibold text-orange-deep">
							{t}
						</span>
					))}
				</div>
			)
		}
	</div>
</article>
